auto.colagemtravel.com {
    encode gzip

    # Log specific to this domain
    log {
        output stderr
        format console
    }

    route /webhook* {
        # uri replace /webhook /
        reverse_proxy ct-webhook:3000
    }

    route /reminders* {
        uri replace /reminders /
        reverse_proxy ct-reminders:3000
    }
}

